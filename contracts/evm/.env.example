# Memba EVM Contracts — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── RPC Endpoints ──────────────────────────────────────────────
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Alchemy (optional — higher reliability + WebSocket support)
# ROBINHOOD_MAINNET_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY
# ROBINHOOD_TESTNET_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/YOUR_KEY

# ── Blockscout Verification ───────────────────────────────────
BLOCKSCOUT_API_KEY=

# ── Deployment ─────────────────────────────────────────────────
# Private key for deployment (NEVER commit the real key)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Samourai Coop Safe multisig — upgrade authority + fee recipient
SAFE_MULTISIG_ADDRESS=

# ── Platform Config ────────────────────────────────────────────
# Platform fee in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250
