# Memba EVM Contracts — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── RPC Endpoints ──────────────────────────────────────────────
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Alchemy (optional — higher reliability + WebSocket support)
# ROBINHOOD_MAINNET_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY
# ROBINHOOD_TESTNET_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/YOUR_KEY

# ── Blockscout Verification ───────────────────────────────────
BLOCKSCOUT_API_KEY=

# ── Deployment ─────────────────────────────────────────────────
# Private key for deployment. NEVER commit the real key.
#
# This field previously shipped with Anvil's account-0 key pre-filled — one of the
# most widely known private keys in Ethereum. Anyone who copied this file, filled in
# only SAFE_MULTISIG_ADDRESS and ran the script would have deployed from a key the
# whole world controls. Left empty so the script fails closed instead.
DEPLOYER_PRIVATE_KEY=

# Samourai Coop Safe multisig — operational admin + fee recipient
SAFE_MULTISIG_ADDRESS=

# Treasury for protocol fees. Defaults to the Safe when unset.
# TREASURY_ADDRESS=

# ── Key separation (required) ──────────────────────────────────
# Operational server key: mints badges, attests quests. REQUIRED, no default.
#
# This must NOT be the upgrade authority. It used to be both — MembaBadges gated
# _authorizeUpgrade on onlyMinter and MembaQuests on onlyVerifier — so a backend
# compromise meant an attacker could replace those contracts outright. It also used
# to default to the Safe when unset, which silently broke minting instead. The deploy
# script now requires it explicitly and rejects it equalling the upgrade authority.
BACKEND_VERIFIER=

# ── Upgrade timelock ───────────────────────────────────────────
# Delay in seconds before a scheduled upgrade can execute. When set, the deploy script
# creates a TimelockController (Safe as proposer/executor, admin = address(0) so the
# delay cannot be re-granted around) and makes it the upgrade authority.
# §17.2 of the strategy makes 48h mandatory for production.
#
# Leave unset for local/testnet iteration — the script warns loudly that upgrades are
# immediate. MUST be set before mainnet.
# TIMELOCK_DELAY=172800

# ── Platform Config ────────────────────────────────────────────
# Platform fee in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250
