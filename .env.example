# Memba — Environment Variables
# Copy this file to .env and fill in your values.

# Backend
PORT=8080
GNO_RPC_URL=https://rpc.test11.testnets.gno.land:443
GNO_CHAIN_ID=test11
DB_PATH=./memba.db
CORS_ORIGINS=http://localhost:5173,https://memba.samourai.app
AUTH_TOKEN_EXPIRY=24h
ED25519_SEED=  # 64-char hex string for deterministic ed25519 keypair (generate with: openssl rand -hex 32)

# GitHub OAuth (create at github.com/organizations/YOUR_ORG/settings/applications)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Frontend (VITE_ prefix for client-side access)
VITE_API_URL=http://localhost:8080
VITE_GNO_CHAIN_ID=test11
VITE_GNO_RPC_URL=https://rpc.test11.testnets.gno.land:443
VITE_GITHUB_CLIENT_ID=
VITE_DAO_REALM_PATH=gno.land/r/samcrew/samourai_dao
VITE_GNOLOVE_API_URL=https://gnolove.world
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# IPFS Pinning — Lighthouse (v2.1a avatars, 5GB free)
VITE_LIGHTHOUSE_API_KEY=