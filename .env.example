# Memba — Environment Variables
# Copy this file to .env and fill in your values.

# Backend
PORT=8080
GNO_RPC_URL=https://rpc.testnet13.samourai.live:443
GNO_CHAIN_ID=test-13
DB_PATH=./memba.db
CORS_ORIGINS=http://localhost:5173,https://memba.samourai.app
AUTH_TOKEN_EXPIRY=24h
ED25519_SEED=  # 64-char hex string for deterministic ed25519 keypair (generate with: openssl rand -hex 32)

# NFT marketplace indexer (the NFT realms live on test13 — its OWN rpc, NOT GNO_RPC_URL)
NFT_RPC_URL=https://rpc.test13.testnets.gno.land:443
NFT_COLLECTION_REALM=gno.land/r/samcrew/memba_nft_v2
NFT_MARKET_REALM=gno.land/r/samcrew/memba_nft_market_v2
NFT_COLLECTION_ID=genesis
NFT_POLL_INTERVAL=60s
# Blocks to stay behind the chain tip for reorg-safety (default 5).
NFT_CONFIRMATIONS=5
# Realms the event tailer watches (v2 market + v2 collection + v3.1 + v3.2 engines).
# v3 is retired (UnregisterMarket'd 2026-06-27). v3.2 is the active engine since
# the 2026-07-10 ceremony; v3.1 stays registered but paused in wind-down.
NFT_WATCHED_REALMS=gno.land/r/samcrew/memba_nft_market_v2,gno.land/r/samcrew/memba_nft_v2,gno.land/r/samcrew/memba_nft_market_v3_1,gno.land/r/samcrew/memba_nft_market_v3_2
# Engines whose volume is sourced from Sale events only; their companion
# OfferAccepted/PurchaseConfirmed are metadata-only (prevents v2→v3 double-count).
# v3_2 added at the 2026-07-10 repoint. Its SeedSale replays emit "SaleSeeded" (NOT
# "Sale"), so watching both engines cannot double-count the migrated history.
NFT_SALE_VOLUME_REALMS=gno.land/r/samcrew/memba_nft_market_v3_1,gno.land/r/samcrew/memba_nft_market_v3_2
# One-time operator backfill lever: seeds a realm's indexer cursor to
# deployHeight-1 if it has no cursor row yet (INSERT OR IGNORE — will NOT
# rewind a realm whose cursor has already advanced). Format: comma-separated
# "realm_pkg_path@deployHeight" pairs.
# Example: NFT_SEED_REALM_CURSOR=gno.land/r/samcrew/memba_nft_market_v3@280000
NFT_SEED_REALM_CURSOR=

# GitHub OAuth (create at github.com/organizations/YOUR_ORG/settings/applications)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Frontend (VITE_ prefix for client-side access)
VITE_API_URL=http://localhost:8080
VITE_GNO_CHAIN_ID=test13
VITE_GNO_RPC_URL=https://rpc.testnet13.samourai.live:443
VITE_GITHUB_CLIENT_ID=
# test13 endpoint overrides — the official endpoints are baked into config.ts;
# set these only to point a build at a different node/indexer/explorer/gnoweb.
# VITE_TEST13_RPC_URL=https://rpc.test13.testnets.gno.land:443
# VITE_TEST13_INDEXER_URL=https://indexer.test13.testnets.gno.land/graphql/query
# VITE_TEST13_EXPLORER_URL=https://test13.testnets.gno.land
# VITE_TEST13_GNOWEB_URL=https://test13.testnets.gno.land
# Bech32 address prefix ("g" on every gno.land network today; override for exotic chains).
# VITE_GNO_BECH32_PREFIX=g
VITE_DAO_REALM_PATH=gno.land/r/samcrew/memba_dao  # Canonical Memba dApp DAO. Note: samourai_dao is a separate Samouraï Coop DAO, not related.
# Realm path overrides — defaults (in config.ts) are the live test13 realms;
# set these only when pointing at a redeployed/renamed realm.
# VITE_CANDIDATURE_REALM_PATH=gno.land/r/samcrew/memba_dao_candidature_v3
# VITE_CHANNELS_REALM_PATH=gno.land/r/samcrew/memba_dao_channels_v2
# VITE_FEED_REALM_PATH=gno.land/r/samcrew/memba_feed_v1
# VITE_REVIEWS_REALM_PATH=gno.land/r/samcrew/memba_reviews_v1
VITE_GNOLOVE_API_URL=https://backend.gnolove.world
VITE_GNO_MONITORING_API_URL=https://monitoring.gnolove.world  # Validator monikers/uptime (gnomonitoring API)

# Note: gnomonitoring uses the RPC chain ID (e.g. "gnoland1", "test12").
# The community name "betanet" maps to chain ID "gnoland1".

# [Alerting] Clerk auth for /alerts page (v2.18)
# Same Clerk app instance as gnolove — reuse the pk_live_ key from gnolove's env.
# Only loaded by the /alerts route (lazy). No impact on other pages.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_

# [Hacker View] Samourai sentry RPC for high-frequency telemetry
# Convention: https://rpc.{chain}.samourai.live
# Examples: https://rpc.testnet13.samourai.live  https://rpc.gnoland1.samourai.live
VITE_SAMOURAI_SENTRY_RPC_URL=
VITE_ENABLE_TEAMS=true
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
VITE_ENABLE_MARKETPLACE=true
# Marketplace v2 rebuild (build-out gate) — OFF until the new version is complete + reviewed, then flipped at cutover.
VITE_ENABLE_MARKETPLACE_V2=false
# Escrow functionality is now live in the Unified Marketplace.
VITE_ENABLE_SERVICES=false
# NFT marketplace (LIVE since 2026-06-27 — v3.1 engine + fee config deployed on test13).
# Removed from SAFETY_GATED_FLAGS in safeFlags.ts; safe to enable in prod.
VITE_ENABLE_NFT=true
# Social feed (W7.2) — ordinary flag, no funds. Off until the memba_feed_v1
# realm is deployed (owner-executed) and the FEED_WATCHED_REALMS backend env is set.
VITE_ENABLE_FEED=false
# On-chain blog reads (memba_blog_v1) with static fallback; off until the realm is deployed + migrated
VITE_ENABLE_ONCHAIN_BLOG=false
# VITE_BLOG_REALM_PATH=gno.land/r/samcrew/memba_blog_v1
# Realm Explorer (W9 P0) — ordinary flag, no funds. Read-only realm viewer
# (qrender/qfile/qfuncs); no execution surface. Off by default.
VITE_ENABLE_EXPLORER=false
# App Store (W9) — SAFETY-GATED until the memba_appstore_v1 fee path is verified on test13.
VITE_ENABLE_APPSTORE=false
# Which App Store realm the front end reads. Defaults to the live v2 realm. Point at the v3
# realm (memba_appstore_v3) ONLY after it's deployed + migrated — that flips on the v3 read
# surface (per-status windows, opt-in pending-review disclosure, screenshots, reject reasons).
# VITE_APPSTORE_REALM_PATH=gno.land/r/samcrew/memba_appstore_v2
# Community reviews on App Store listings (B2b) — ordinary flag, no funds (reputation graph
# only). Off by default; the app-reviews realm is deployed to test13. Turn on to show reviews.
VITE_ENABLE_APP_REVIEWS=false
# Override the App Store reviews realm path (defaults to gno.land/r/samcrew/memba_appstore_reviews_v1).
# VITE_APPSTORE_REVIEWS_REALM_PATH=gno.land/r/samcrew/memba_appstore_reviews_v1
# Space Invaders arcade game (Store). Leave false; owner flips to enable.
VITE_ENABLE_SPACE_INVADERS=false
# gno.land public-sale announcement popup — ordinary flag, no funds (dismissible
# promo linking to the official sale portal). Turn on for the sale window (opens 2026-07-20).
VITE_ENABLE_ICO_ANNOUNCEMENT=false
# Token factory lane (GRC20 create/mint/transfer/burn UI). Ordinary flag.
VITE_ENABLE_TOKENS=false
# Community reviews (validators/profiles; memba_reviews_v1, reputation-only — no funds).
VITE_ENABLE_REVIEWS=false
# Feed reaction bar — needs the feed realm redeployed with the reaction methods (owner-executed).
VITE_ENABLE_REACTIONS=false
# Feed URL unfurls via the backend's SSRF-guarded link-preview proxy.
VITE_ENABLE_LINK_PREVIEWS=false
# Block Party daily game. Leave false — rewards need the signature gate + the
# BLOCKPARTY_ENABLED backend env; owner flips both together.
VITE_ENABLE_GAME=false
# GnoBuilders badges tab on profiles. Flip after the badge mint ceremony.
VITE_ENABLE_BADGES=false
# Agents surface (agent_registry realm). Ordinary flag; credits stay behind
# the safety-gated VITE_ENABLE_AGENT_CREDITS below.
VITE_ENABLE_AGENTS=false
# Profile Activity tab scan window in blocks (~40k ≈ the last 1.5–2 days on
# test13); bounded because the indexer streams full history otherwise.
# VITE_PROFILE_ACTIVITY_WINDOW_BLOCKS=40000
# App Store self-service submission (/apps/submit; RegisterApp sends the exact 1-GNOT
# fee). De-gated 2026-07-10: v3 deployed + seeded + sealed, fee path verified on test13.
VITE_ENABLE_APPSTORE_SUBMIT=false

# AAA-0 safety-gated flags — these features have incomplete on-chain enforcement.
# Changing any to 'true' will fail CI (see safeFlags.ts safety gate).
# A1.a: Treasury spending is NOT yet enforced on-chain.
VITE_ENABLE_TREASURY_SPEND=false
# A5.ui: Agent credit deposits disabled until registry deployment is verified.
VITE_ENABLE_AGENT_CREDITS=false

# DAO Analyst — free-tier LLM API keys (backend-only, never shipped to client)
GROQ_API_KEY=           # Groq free tier (Llama 3.3 70B) — https://console.groq.com
GOOGLE_AI_KEY=          # Google AI Studio free tier (Gemini 2.0 Flash) — https://aistudio.google.com
TOGETHER_API_KEY=       # Together.ai free tier (Mistral) — https://api.together.xyz
OLLAMA_URL=             # Optional: http://localhost:11434 for local Ollama fallback
OLLAMA_MODEL=           # Optional: model name for Ollama (default: llama3.2)

# IPFS Pinning — Lighthouse (v2.1a avatars, 5GB free)
VITE_LIGHTHOUSE_API_KEY=

# JaaS (v2.9)
VITE_JAAS_APP_ID=

OPENROUTER_API_KEY=     # Single key for all 10 free models
ANALYST_CACHE_TTL=6h    # Optional, default 6 hours
VITE_ENABLE_ANALYST=true
