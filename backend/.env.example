# Memba Backend Environment Variables
# Copy to .env and fill in values

# Server port (default: 8080)
PORT=8080

# SQLite database path (default: memba.db)
DB_PATH=memba.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ed25519 seed for token signing (hex-encoded, 64 chars)
# Generate with: openssl rand -hex 32
ED25519_SEED=

# ── Activity feed ────────────────────────────────────────────────────────────
# gno tx-indexer GraphQL endpoint proxied by /api/indexer (the browser can't call
# it directly — no CORS). Defaults to the official test13 indexer.
# INDEXER_GRAPHQL_URL=https://indexer.test13.testnets.gno.land/graphql/query

# ── Home snapshot ────────────────────────────────────────────────────────────
# RPC used by GetHomeSnapshot to read on-chain counts/pulse (defaults to NFT_RPC_URL,
# then the pinned samourai test13 node). The public node rate-limits the Fly egress IP (#466).
HOME_SNAPSHOT_RPC_URL=https://rpc.testnet13.samourai.live:443
# Cache TTL for the assembled home snapshot (Go duration, default 30s).
HOME_SNAPSHOT_TTL=30s

# ── RPC failover ─────────────────────────────────────────────────────────────
# Backup RPC nodes tried (in order) when the primary *_RPC_URL above is
# unreachable (connection error, timeout, non-200). Comma-separated; unset/empty
# uses the built-in trusted test13 list (public node, onbloc, aeddi). A valid
# "no record" answer never triggers failover — only transport failures do.
# RPC_FALLBACK_URLS=https://rpc.test13.testnets.gno.land:443,https://test13.rpc.onbloc.xyz:443

# ── NFT indexer (Render-scrape metadata poller) ──────────────────────────────
# The NFT realms live on test13, so this uses its OWN rpc (not GNO_RPC_URL).
# Pinned samourai node — the public node rate-limits the Fly egress IP (#466).
NFT_RPC_URL=https://rpc.testnet13.samourai.live:443
NFT_COLLECTION_REALM=gno.land/r/samcrew/memba_nft_v2
NFT_MARKET_REALM=gno.land/r/samcrew/memba_nft_market_v2
NFT_COLLECTION_ID=genesis
# Metadata poll interval (Go duration). Default 60s.
NFT_POLL_INTERVAL=60s

# ── NFT event tailer (/block_results → normalized event tables) ───────────────
# Comma-separated realm pkg_paths to watch. Default: market + collection realms.
NFT_WATCHED_REALMS=gno.land/r/samcrew/memba_nft_market_v2,gno.land/r/samcrew/memba_nft_v2
# First-run cursor floor: block height to start tailing from on a fresh DB.
# Set to a height at/just before the NFT realms were deployed to avoid scanning
# all of genesis. Default 260000 (recent test13 height). Once the cursor is
# persisted in nft_indexer_state this is ignored.
NFT_START_BLOCK=260000
# Tailer sleep when caught up to the chain tip (Go duration). Default 3s.
NFT_TAILER_INTERVAL=3s

# ── Social feed indexer (W7.2 — memba_feed_v1 → feed_posts) ───────────────────
# Separate goroutine + cursor + raw ledger from the NFT tailer. UNSET = the feed
# indexer does not start (safe default while the realm is not yet deployed).
# Set to the deployed feed realm pkg_path to enable.
# FEED_WATCHED_REALMS=gno.land/r/samcrew/memba_feed_v1
# RPC for the feed tailer (defaults to NFT_RPC_URL — same chain).
# FEED_RPC_URL=
# First-run cursor floor (block height); ignored once persisted in
# feed_indexer_state. Default 260000. Set to the feed realm's deploy height.
FEED_START_BLOCK=260000
# Confirmations depth and poll interval (Go duration). Defaults 5 / 3s.
FEED_CONFIRMATIONS=5
FEED_TAILER_INTERVAL=3s

# ── Quests ───────────────────────────────────────────────────────────────────
# Comma-separated addresses allowed to review (approve/reject) self-report quest
# claims. Unset/empty keeps the built-in default (samcrew-core-test1). Setting it
# REPLACES the default — add/rotate reviewers without a code change or redeploy.
# QUEST_ADMIN_ADDRESSES=g1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,g1yyyy...

# ── BARRICADE on-chain certify (verified arcade run submissions) ─────────────
# The /api/arcade/submit endpoint re-simulates a submitted input log in a node
# subprocess and stores only the reproduced result. UNSET/not "1" = the endpoint
# is 404 (safe default while the feature is dark and the realm isn't deployed).
# Needs `node` on PATH (the runtime image ships it). Set to "1" to enable.
# MEMBA_ARCADE_SUBMIT_ENABLED=1
# Override the node binary used to run the verify worker (default: node).
# MEMBA_ARCADE_NODE_BIN=node
# Per-authenticated-wallet submit cap (requests/min). Default 20.
# MEMBA_ARCADE_SUBMIT_RPM=20

# ── BARRICADE day-close attester (writes the competitive board on-chain) ─────
# DORMANT until BOTH are set. The attester re-attests each closed day's best
# verified run per wallet to the leaderboard realm via a dedicated low-privilege
# gnokey key (attester-pays). The key ceremony — generate + FUND the key and
# AddAttester it on the realm (NEVER the deploy multisig) — is an OWNER step, and
# the runtime image must carry `gnokey` (a build-stage add; see the ceremony
# runbook). Without gnokey on PATH the attester self-disables with a warning.
# MEMBA_ARCADE_ATTESTER_ENABLED=1
# gnokey keyring name of the attester key (NOT a raw secret; imported at ceremony).
# MEMBA_ARCADE_ATTESTER_KEY=arcade-attester
# Leaderboard realm (default is the deployed path once the realm ceremony runs).
# MEMBA_ARCADE_REALM=gno.land/r/samcrew/memba_arcade_leaderboard_v1
# RPC for attestation broadcasts (defaults to GNO_RPC_URL).
# MEMBA_ARCADE_RPC_URL=
# gnokey binary (default: gnokey). Scan cadence + per-cycle attestation cap.
# MEMBA_ARCADE_GNOKEY_BIN=gnokey
# MEMBA_ARCADE_ATTEST_INTERVAL=15m
# MEMBA_ARCADE_ATTEST_MAX_PER_CYCLE=100
