# Memba Backend Environment Variables
# Copy to .env and fill in values

# Server port (default: 8080)
PORT=8080

# SQLite database path (default: memba.db)
DB_PATH=memba.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ed25519 seed for token signing (hex-encoded, 64 chars)
# Generate with: openssl rand -hex 32
ED25519_SEED=

# ── Activity feed ────────────────────────────────────────────────────────────
# gno tx-indexer GraphQL endpoint proxied by /api/indexer (the browser can't call
# it directly — no CORS). Defaults to the official test13 indexer.
# INDEXER_GRAPHQL_URL=https://indexer.test13.testnets.gno.land/graphql/query

# ── Home snapshot ────────────────────────────────────────────────────────────
# RPC used by GetHomeSnapshot to read on-chain counts/pulse (defaults to NFT_RPC_URL,
# then the pinned samourai test13 node). The public node rate-limits the Fly egress IP (#466).
HOME_SNAPSHOT_RPC_URL=https://rpc.testnet13.samourai.live:443
# Cache TTL for the assembled home snapshot (Go duration, default 30s).
HOME_SNAPSHOT_TTL=30s

# ── RPC failover ─────────────────────────────────────────────────────────────
# Backup RPC nodes tried (in order) when the primary *_RPC_URL above is
# unreachable (connection error, timeout, non-200). Comma-separated; unset/empty
# uses the built-in trusted test13 list (public node, onbloc, aeddi). A valid
# "no record" answer never triggers failover — only transport failures do.
# RPC_FALLBACK_URLS=https://rpc.test13.testnets.gno.land:443,https://test13.rpc.onbloc.xyz:443

# ── NFT indexer (Render-scrape metadata poller) ──────────────────────────────
# The NFT realms live on test13, so this uses its OWN rpc (not GNO_RPC_URL).
# Pinned samourai node — the public node rate-limits the Fly egress IP (#466).
NFT_RPC_URL=https://rpc.testnet13.samourai.live:443
NFT_COLLECTION_REALM=gno.land/r/samcrew/memba_nft_v2
NFT_MARKET_REALM=gno.land/r/samcrew/memba_nft_market_v2
NFT_COLLECTION_ID=genesis
# Metadata poll interval (Go duration). Default 60s.
NFT_POLL_INTERVAL=60s

# ── NFT event tailer (/block_results → normalized event tables) ───────────────
# Comma-separated realm pkg_paths to watch. Default: market + collection realms.
NFT_WATCHED_REALMS=gno.land/r/samcrew/memba_nft_market_v2,gno.land/r/samcrew/memba_nft_v2
# First-run cursor floor: block height to start tailing from on a fresh DB.
# Set to a height at/just before the NFT realms were deployed to avoid scanning
# all of genesis. Default 260000 (recent test13 height). Once the cursor is
# persisted in nft_indexer_state this is ignored.
NFT_START_BLOCK=260000
# Tailer sleep when caught up to the chain tip (Go duration). Default 3s.
NFT_TAILER_INTERVAL=3s

# ── Quests ───────────────────────────────────────────────────────────────────
# Comma-separated addresses allowed to review (approve/reject) self-report quest
# claims. Unset/empty keeps the built-in default (samcrew-core-test1). Setting it
# REPLACES the default — add/rotate reviewers without a code change or redeploy.
# QUEST_ADMIN_ADDRESSES=g1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,g1yyyy...
