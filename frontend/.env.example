# Memba Frontend Environment Variables
# Copy to .env.local and fill in values

# Backend API URL (ConnectRPC). Empty = uses Vite proxy (dev) or same-origin (prod)
VITE_API_URL=

# Gno chain ID
VITE_GNO_CHAIN_ID=test11

# Gno RPC endpoint (ABCI queries, broadcast)
VITE_GNO_RPC_URL=https://rpc.test11.testnets.gno.land:443

# [Hacker Mode] Samourai Sentry/Validator node RPC for direct high-frequency telemetry.
# When set, Hacker Mode will use this endpoint for /dump_consensus_state and /net_info.
# Falls back to VITE_GNO_RPC_URL if empty or unreachable.
# Example: https://samourai-dev-sentry.example.com:26657
VITE_SAMOURAI_SENTRY_RPC_URL=

# Bech32 address prefix
VITE_GNO_BECH32_PREFIX=g

# JaaS (Jitsi-as-a-Service) App ID for lobby-free voice/video rooms.
# Get a free App ID at https://jaas.8x8.vc — leave empty to fallback to meet.jit.si.
VITE_JAAS_APP_ID=
